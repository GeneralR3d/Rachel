# Rename this file to `.env` and fill in your credentials.

# --- Telegram app (identifies your client app; from my.telegram.org) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Admin bot token (the second bot, from @BotFather) ---
TELEGRAM_BOT_TOKEN=

# --- Openrouter ---
OPENROUTER_API_KEY=
# Separate key billed for everything Graphiti/world-view related (fact
# extractor LLM, Graphiti's LLM/embedder/reranker). Leave blank to reuse
# OPENROUTER_API_KEY.
OPENROUTER_GRAPHITI_API_KEY=



OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Model id (routed via OpenRouter) used for Graphiti's embeddings. The same
# OPENROUTER_API_KEY + OpenAI-compatible base URL covers LLM, embeddings, and
# reranking, so no separate embeddings provider/key is needed.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Override only if you self-host or proxy OpenRouter:
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Your personal Telegram user id (from @userinfobot) ---
ADMIN_ID=

# --- Optional names (default to "Rachel" / unset) ---
BOT_NAME=Rachel
USER_NAME=

# --- Postgres (matches docker-compose.yml) ---
# Password for the dockerized Postgres. docker-compose reads this for
# POSTGRES_PASSWORD, and the app's DATABASE_URL below expands ${DB_PASSWORD}
# (python-dotenv interpolation), so the password lives in exactly one place.
# Must be defined ABOVE DATABASE_URL (dotenv resolves top-down). If the password
# contains URL-special chars (@ : / #), URL-encode them in DATABASE_URL.
DB_PASSWORD=rachel
# When running the app locally against the dockerized DB:
DATABASE_URL=postgresql+asyncpg://rachel:${DB_PASSWORD}@localhost:5433/rachel
# When running the app *inside* docker-compose, use host `db` instead. Keep this
# one literal — it's read via Compose env injection, which won't expand ${...}:
# DATABASE_URL=postgresql+asyncpg://rachel:rachel@db:5432/rachel

# --- Neo4j (Graphiti world-view knowledge graph; matches docker-compose.yml) ---
# Password for the dockerized Neo4j; docker-compose reads this for NEO4J_AUTH.
NEO4J_PASSWORD=
NEO4J_USER=neo4j
# When running the app locally against the dockerized Neo4j (loopback-mapped):
NEO4J_URI=bolt://localhost:7687
# When running the app *inside* docker-compose, use host `neo4j` instead:
# NEO4J_URI=bolt://neo4j:7687

# NOTE: Rachel's own bot token is NOT stored here. It is entered once,
# interactively, when you run `uv run python -m scripts.login` (saved to anon.session).
